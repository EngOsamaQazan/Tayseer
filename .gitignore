# ═══════════════════════════════════════════════
#  Jadal ERP — .gitignore
# ═══════════════════════════════════════════════

# yii console commands (generated by init)
/yii
/yii_test
/yii_test.bat

# IDE / Editor
.idea
.vscode
nbproject
.buildpath
.project
.settings
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
desktop.ini

# Composer
/vendor
composer.phar
composer.lock

# Node
node_modules/

# phpunit
phpunit.phar
/phpunit.xml

# Runtime & generated files
/backend/runtime/
/frontend/runtime/
/console/runtime/
/api/runtime/

# Generated web files (created by init)
/frontend/web/index.php
/frontend/web/index-test.php
/frontend/web/robots.txt
/backend/web/index.php
/backend/web/index-test.php
/backend/web/robots.txt

# Uploaded content
/backend/web/images/
/backend/web/uploads/

# Local config (generated by init)
/common/config/main-local.php
/common/config/params-local.php
/backend/config/main-local.php
/backend/config/params-local.php
/frontend/config/main-local.php
/frontend/config/params-local.php
/console/config/main-local.php
/console/config/params-local.php

# Logs
*.log

# Docker volumes
mysql_data/

# Database dumps (large files)
*.sql

# Temporary scripts
/scripts/temp/

# Deploy config (contains credentials)
deploy.config
sshpass.exe

# Google Cloud credentials — NEVER commit
backend/config/credentials/
*.gserviceaccount.json
tayseerai-*.json

# Published assets (auto-generated by Yii2)
/backend/web/assets/*/

# Binary tools (Windows-only, not for server)
/backend/bin/

# Python cache
__pycache__/
*.pyc

# Temp utility scripts
check_cols.php
check_companies.php
test_api.php
fix-configs.py

# Deploy scripts (contain server credentials)
/scripts/deploy_vite_tar.py
/scripts/deploy_vite_subdomains.py
/scripts/deploy_git.py
/scripts/_*.py

# Temp debug/fix scripts (contain credentials)
/scripts/debug_*.py
/scripts/fix_*
/scripts/check_*.py
/scripts/get_error.py
/scripts/whats_wrong.py
/scripts/deep_debug.py
/scripts/restore_prod.py
/scripts/upload_fix_ext.py
/scripts/run_fix_*.py

# Debug diagnostic files
/backend/web/test-width.html

# Internal notes
/notes.md
