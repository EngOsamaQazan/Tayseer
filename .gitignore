# ═══════════════════════════════════════════════
#  Tayseer ERP (نظام تيسير) — .gitignore
# ═══════════════════════════════════════════════

# ─── Yii2 Console (generated by init) ─────────
/yii
/yii_test
/yii_test.bat

# ─── IDE / Editor ─────────────────────────────
.idea/
.vscode/
nbproject/
.buildpath
.project
.settings/
*.swp
*.swo

# ─── OS ───────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ─── Composer ─────────────────────────────────
/vendor/
composer.phar
composer.lock

# ─── Node ─────────────────────────────────────
node_modules/

# ─── PHPUnit ──────────────────────────────────
phpunit.phar
/phpunit.xml

# ─── Runtime (generated by Yii2) ──────────────
/backend/runtime/
/frontend/runtime/
/console/runtime/
/api/runtime/

# ─── Generated web files (created by init) ────
/frontend/web/index.php
/frontend/web/index-test.php
/frontend/web/robots.txt
/backend/web/index.php
/backend/web/index-test.php
/backend/web/robots.txt

# ─── Uploaded content ─────────────────────────
/backend/web/images/*
!/backend/web/images/favicon.png
/backend/web/uploads/

# ─── Local config (generated by init) ─────────
/common/config/main-local.php
/common/config/params-local.php
/backend/config/main-local.php
/backend/config/params-local.php
/frontend/config/main-local.php
/frontend/config/params-local.php
/console/config/main-local.php
/console/config/params-local.php

# ─── Logs ─────────────────────────────────────
*.log

# ─── Docker volumes ───────────────────────────
mysql_data/

# ─── Database (dumps, migrations, seeds) ─────
/database/
*.sql

# ─── Scripts (contain server credentials) ──────
/scripts/temp/

# ─── Deploy config (contains credentials) ─────
deploy.config
sshpass.exe

# ─── Admin panel config (contains credentials) ─
/admin/config.php

# ─── Google Cloud credentials ─────────────────
backend/config/credentials/
*.gserviceaccount.json
tayseerai-*.json

# ─── Published assets (auto-generated) ────────
/backend/web/assets/*/

# ─── Binary tools ─────────────────────────────
/backend/bin/

# ─── Python cache ─────────────────────────────
__pycache__/
*.pyc

# ─── Inno Setup build output ─────────────────
scripts/deploy/Output/
scripts/deploy/platform-tools.zip
scripts/deploy/*.exe

# ─── Temp utility scripts ─────────────────────
check_cols.php
check_companies.php
test_api.php
fix-configs.py

# ─── Diagnostics / debug ──────────────────────
/backend/web/test-width.html
/docs/diagnostics/

# ─── Internal notes ───────────────────────────
/notes.md

# ─── Agent / Playwright session artifacts ─────
/.playwright-mcp/

# ─── UX/QA audit screenshots ──────────────────
# Screenshots used for one-off design reviews; the source of truth lives
# in design docs / tickets, not the repo.
/ux-audit/
/*.png
/*.jpeg
/*.jpg
!/social-preview.png

# ─── Throwaway diagnostic / migration scripts ─
# By convention every ad-hoc helper added during a debug session is
# prefixed with an underscore. They contain hard-coded local paths and
# DB credentials, so we keep them out of the repo.
/scripts/_*
/scripts/deploy/_*
/scripts/inspect_*
/scripts/migrate_*

# ─── Plain-text credentials (never commit) ────
/scripts/credentials.py
*cookies.txt
*.cookies.txt

# ─── Local-only operational scripts ───────────
# Most ad-hoc helpers in scripts/ have hard-coded server passwords or
# tokens inlined while we were doing migration / hot-fix work, so they
# stay local. Only the curated, cloud-essential set (refactored to load
# secrets from credentials.py) is whitelisted below.
/scripts/*.py
/scripts/*.php
/scripts/*.sh
/scripts/*.bat
/scripts/check/
/scripts/debug/
/scripts/fix/
/scripts/verify/
/scripts/server/
/scripts/setup/
/scripts/upgrade/
/scripts/migration/
/scripts/dns/
/scripts/backup/
/scripts/deploy/
/scripts/misc/

# ── Whitelist: cloud-essential scripts that read from credentials.py ──
!/scripts/credentials.example.py
!/scripts/setup_server_git.py
!/scripts/backup/
/scripts/backup/*
!/scripts/backup/backup.py
!/scripts/deploy/
/scripts/deploy/*
!/scripts/deploy/deploy.py
!/scripts/dns/
/scripts/dns/*
!/scripts/dns/update_dns.py
!/scripts/setup/
/scripts/setup/*
!/scripts/setup/install-phpmyadmin.py
!/scripts/setup/setup-tayseer.ps1
!/scripts/migration/
/scripts/migration/*
!/scripts/migration/MIGRATION_GUIDE.md
!/scripts/migration/hestia_remote_install.sh
!/scripts/migration/01_setup_new_server.py
!/scripts/migration/02_migrate_data.py
!/scripts/migration/03_setup_vhosts_ssl.py
!/scripts/migration/04_verify_and_switch.py
!/scripts/migration/05_update_deploy_scripts.py
!/scripts/migration/06_install_hestiacp.py
!/scripts/migration/06b_launch_hestia_install.py
!/scripts/migration/06c_run_hestia_direct.py
!/scripts/migration/07_check_and_fix.py
!/scripts/migration/08_fix_and_install_hestia.py
!/scripts/migration/09_final_hestia_fix.py
!/scripts/migration/10_fix_and_install_webmin.py
!/scripts/migration/11_webmin_and_restore_db.py
!/scripts/migration/12_install_webmin_deb.py
!/scripts/migration/13_webmin_ssl.py
!/scripts/server/
/scripts/server/*
!/scripts/server/check-server.py
!/scripts/server/check-server-alive.py
!/scripts/server/check-server-specs.py
!/scripts/server/check-ssh-ports.py
!/scripts/server/check-production.py
!/scripts/server/fix-production.py
!/scripts/server/fix-server-config.py
!/scripts/server/analyze-disk.py
!/scripts/server/optimize-new-server.py
!/scripts/server/server-cleanup-secure.py
!/scripts/server/server-stats.py
!/scripts/upgrade/
/scripts/upgrade/*
!/scripts/upgrade/upgrade-debian12.py
!/scripts/upgrade/upgrade-debian12-fix.py
!/scripts/upgrade/upgrade-php85.py
!/scripts/upgrade/upgrade-php85-v2.py
!/scripts/upgrade/upgrade-php85-v3.py
!/scripts/upgrade/upgrade-php85-go.py
!/scripts/upgrade/upgrade-php85-final.py
!/scripts/upgrade/post-upgrade-verify.py
!/scripts/upgrade/post-upgrade-dbcheck.py

# ─── Local agent / IDE state ──────────────────
/.claude/

# ─── Separate v2 monorepo (not tracked here) ──
/tayseer-v2/

# ─── One-off probe / dump artefacts at repo root ─
/probe_*.bat
/zajal_*.bat
/zajal_*.html
/z_api.html
/verify_backend.bat
